# Access password (required) — protects your running instance from casual visitors
ACCESS_PASSWORD=change-me

# API keys (at least one required)
# See docs/getting-started/api-keys.md for signup links + pricing
CLAUDE_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Optional: change if 3000 is busy
# PORT=3001

# Optional: contact email sent as HTTP `From` header on arXiv requests.
# arXiv's API docs ask clients to identify themselves. Institutional
# addresses carry more weight with their abuse heuristics than webmail.
# ARXIV_CONTACT_EMAIL=you@example.edu
