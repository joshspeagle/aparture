# Vercel uploads everything except files matched here. Default behavior also
# respects .gitignore, but several heavy directories are gitignored AND
# present in the working tree (runtime state). Listing them here keeps them
# out of the build context.

# Runtime state (generated by `npm run analyze`, `npm run dev`)
reports/
temp/
.next/
.vercel/

# CLI browser automation (scheduled for Phase 2 deletion; not used by the web app)
cli/

# Test infrastructure (huge fixtures, never run on Vercel)
tests/

# VitePress documentation (separate Pages deploy; has its own node_modules)
docs/

# Repo-only tooling (not needed at runtime)
scripts/
.claude/
.husky/
.github/

# IMPORTANT: do NOT list these — they ARE needed at runtime
#   prompts/   — API routes load these via fs.readFile at request time
#   pages/, lib/, components/, hooks/, stores/, styles/, utils/ — Next.js app code

# Editor / OS
.vscode/
.idea/
.DS_Store
